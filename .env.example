# Database (SQLite for dev — swap for Postgres URL in production)
DATABASE_URL=file:../.data/dev.db

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin Basic Auth (used by middleware to protect /admin)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Email notifications (Resend). Leave blank to log to console instead.
RESEND_API_KEY=
EMAIL_FROM="Nile Horizons <hello@nilehorizons.example>"
ADMIN_EMAIL=ops@nilehorizons.example

# Used for absolute URLs in checkout, sitemap, hreflang
PUBLIC_BASE_URL=http://localhost:3000
