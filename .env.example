# Database (SQLite for dev — swap for Postgres URL in production)
DATABASE_URL=file:../.data/dev.db

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin Basic Auth (used by middleware to protect /admin)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Email notifications (Resend). Leave blank to log to console instead.
RESEND_API_KEY=
EMAIL_FROM="Nile Horizons <hello@nilehorizons.example>"
ADMIN_EMAIL=ops@nilehorizons.example

# Used for absolute URLs in checkout, sitemap, hreflang
PUBLIC_BASE_URL=http://localhost:3000

# Plausible analytics (privacy-friendly, no consent banner needed in EU).
# Leave NEXT_PUBLIC_PLAUSIBLE_DOMAIN blank to disable.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# Sentry error monitoring. Leave NEXT_PUBLIC_SENTRY_DSN blank to disable
# entirely. SENTRY_AUTH_TOKEN is only needed to upload sourcemaps at build.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=production
NEXT_PUBLIC_SENTRY_TRACES_RATE=0.1
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
